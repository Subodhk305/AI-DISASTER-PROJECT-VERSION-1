# Server
DEBUG=True
SECRET_KEY=your-super-secret-key-change-this-in-production

# Database
MONGODB_URL=mongodb://localhost:27017
DATABASE_NAME=disaster_system

# ML Services (Update with actual IPs of your laptops)
EARTHQUAKE_API_URL=http://192.168.1.10:8001
RAINFALL_API_URL=http://192.168.1.11:8002
FLOOD_API_URL=http://192.168.1.12:8003

# Email (Configure for production)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=alerts@disaster-system.com

# Alert Thresholds
EARTHQUAKE_THRESHOLD=0.6
RAINFALL_THRESHOLD=50
FLOOD_THRESHOLD=0.6